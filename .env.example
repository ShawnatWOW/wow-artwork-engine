# WOW Artwork Engine — environment template.
# Copy to .env (gitignored) and fill in. NEVER commit real secrets.
# In production these come from AWS Secrets Manager; env is the local fallback.

# ---- App ----
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ---- Postgres (AWS RDS in prod) ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wow_artwork
# Set to "require" against RDS.
PGSSLMODE=disable

# ---- AWS ----
AWS_REGION=us-west-2
S3_BUCKET=wow-artwork-engine
# Optional: pull secrets from Secrets Manager instead of this file.
# Comma-separated secret IDs; their JSON keys are merged into the environment.
SECRETS_MANAGER_IDS=

# ---- Asset store ----
# local = keep generated media on disk (default; $0, no AWS). s3 = upload to S3_BUCKET.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=var/storage

# ---- Curation ----
# Options per surface Scott reviews each week (locked: 3).
OPTIONS_PER_SURFACE=3

# ---- Generation defaults ----
# Clip length + frame rate for generated media. Short keeps fixture runs fast.
GEN_DURATION_S=6
GEN_FPS=30

# ---- Generation mode ----
# fixture = run the whole pipeline on synthetic FFmpeg-generated media (no cost).
# live    = call the real paid APIs. Requires the keys below AND explicit opt-in.
GENERATION_MODE=fixture

# ---- Generation models: all on fal.ai ----
# Stills = Seedream (its stills are the first-frame reference for Seedance).
# Motion = Seedance 2.0 image-to-video (animates the approved still).
# 4K path = Seedance Standard @1080p, then Topaz Video Upscale (billboard scale).
FAL_KEY=
# Defaults (only set to override):
#FAL_SEEDREAM_MODEL=fal-ai/bytedance/seedream/v4/text-to-image
#FAL_SEEDANCE_MODEL=bytedance/seedance-2.0/image-to-video   # add /fast for cheap 720p tier
#FAL_RESOLUTION=1080p
#FAL_UPSCALE=1                    # 0 disables the Topaz 4K pass
#FAL_UPSCALE_MODEL=fal-ai/topaz/upscale/video
#FAL_UPSCALE_FACTOR=2
FAL_QUEUE_BASE=https://queue.fal.run

# ---- Spend-strip estimate rates (USD) ----
# fal's REAL published prices (verified 2026-07-19), itemized per operation.
# The fal account is SHARED across WOW Artwork + Content Automation + Broken
# News, so fal's own billing API reports all three combined — this per-
# generation estimate is the only artwork-specific figure.
#COST_STILL_USD=0.03                    # Seedream v4, per image
#COST_SEEDANCE_STD_PER_SECOND_USD=0.68  # Seedance 2.0 standard @1080p, per raw second
#COST_SEEDANCE_FAST_PER_SECOND_USD=0.30 # Seedance 2.0 /fast @720p, per raw second
#COST_TOPAZ_PER_SECOND_USD=0.08         # Topaz upscale to >1080p (4K), per second

# ---- Brand guardrails (locked: loose — block nudity only) ----
GUARDRAILS_BLOCK_NUDITY=true
# Optional comma-separated extra terms to deny in prompts.
GUARDRAILS_EXTRA_DENY_TERMS=

# ---- Delivery (locked: Google Drive) ----
DELIVERY_METHOD=drive
GOOGLE_DRIVE_FOLDER_ID=
# Auth: EITHER a service-account JSON string …
GOOGLE_SERVICE_ACCOUNT_JSON=
# … OR an OAuth refresh token + client creds.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ---- Delivery fallback: WOW FTP (optional) ----
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_SECURE=false
FTP_REMOTE_DIR=/incoming

# ---- Jeff notification: Gmail API + Google service account ----
# Sends AS a real @wowmedia.com person (no SMTP). Reuses GOOGLE_SERVICE_ACCOUNT_JSON
# above; that SA needs domain-wide delegation for scope gmail.send.
# Unconfigured = OFFLINE: files saved locally + a .eml written, reported as NOT sent.
PUBLISH_SENDERS=scott@wowmedia.com,shawn@wowmedia.com
PUBLISH_FROM=scott@wowmedia.com
PUBLISH_TO=jeff@wowmedia.com
PUBLISH_DOMAIN=wowmedia.com
# Where offline handoffs land (local fallback).
HANDOFF_LOCAL_DIR=var/handoff

# ---- FFmpeg ----
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ---- Scheduler ----
# Day-of-week + time the weekly run fires (cron, container TZ).
WEEKLY_RUN_CRON=0 9 * * 1
# In-process scheduler is opt-in. Leave false in dev/CI; set true in production.
SCHEDULER_ENABLED=false
